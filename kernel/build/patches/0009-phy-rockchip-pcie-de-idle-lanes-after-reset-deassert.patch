From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Wed, 17 Jun 2026 15:00:00 +0100
Subject: [PATCH] phy: rockchip-pcie: De-idle lanes after PHY reset deassert

Linux 6.1 deasserted the RK3399 PCIe PHY reset before taking a lane out
of idle.  A later change moved the lane de-idle write ahead of the shared
PHY power-on counter so all four lanes are enabled when required, but that
also means the first lane is taken out of idle while the shared PHY reset
is still asserted.

Keep the newer all-lane behaviour: repeated phy_power_on() calls still
clear idle for each lane.  Move the de-idle write so it happens only after
the shared PHY reset has been deasserted, matching the known-good RK3399
initialization ordering more closely without reverting the multi-lane fix.

Signed-off-by: Codex <codex@local>
---
--- a/drivers/phy/rockchip/phy-rockchip-pcie.c
+++ b/drivers/phy/rockchip/phy-rockchip-pcie.c
@@ -97,6 +97,13 @@
 		     FIELD_PREP_WM16(PHY_CFG_WR_MASK, PHY_CFG_WR_DISABLE));
 }
 
+static void rockchip_pcie_phy_deidle_lane(struct rockchip_pcie_phy *rk_phy, unsigned int lane)
+{
+	regmap_write(rk_phy->reg_base, rk_phy->phy_data->pcie_laneoff,
+		     FIELD_PREP_WM16(PHY_LANE_IDLE_MASK,
+				     !PHY_LANE_IDLE_OFF) << lane);
+}
+
 static int rockchip_pcie_phy_power_off(struct phy *phy)
 {
 	struct phy_pcie_instance *inst = phy_get_drvdata(phy);
@@ -135,11 +142,8 @@
 
 	guard(mutex)(&rk_phy->pcie_mutex);
 
-	regmap_write(rk_phy->reg_base, rk_phy->phy_data->pcie_laneoff,
-		     FIELD_PREP_WM16(PHY_LANE_IDLE_MASK,
-				     !PHY_LANE_IDLE_OFF) << inst->index);
-
 	if (rk_phy->pwr_cnt++) {
+		rockchip_pcie_phy_deidle_lane(rk_phy, inst->index);
 		return 0;
 	}
 
@@ -153,6 +157,8 @@
 	regmap_write(rk_phy->reg_base, rk_phy->phy_data->pcie_conf,
 		     FIELD_PREP_WM16(PHY_CFG_ADDR_MASK, PHY_CFG_PLL_LOCK));
 
+	rockchip_pcie_phy_deidle_lane(rk_phy, inst->index);
+
 	/*
 	 * No documented timeout value for phy operation below,
 	 * so we make it large enough here. And we use loop-break

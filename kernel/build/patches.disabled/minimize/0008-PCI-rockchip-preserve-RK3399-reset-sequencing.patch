From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Wed, 17 Jun 2026 09:00:00 +0100
Subject: [PATCH] PCI: rockchip: Preserve RK3399 reset sequencing

The reset-bulk conversion changed RK3399 PCIe reset ordering. The
original driver asserted the PM-related resets as aclk, pclk, pm, then
released them as pm, aclk, pclk. It also asserted the core-related resets
as core, mgmt, mgmt-sticky, pipe, then released them as mgmt-sticky,
core, mgmt, pipe.

A single reset_control_bulk_*() array cannot express both assert and
deassert order when they are not simple reverses of each other. Keep the
newer driver's bulk-acquired reset storage, but drive the PM reset
sequence explicitly and drive the core reset assert sequence explicitly.
Leave core reset deassertion on reset_control_bulk_deassert(), because the
array was already ordered so the bulk reverse deassert path matches the
historical RK3399 sequence.
---
--- a/drivers/pci/controller/pcie-rockchip.c
+++ b/drivers/pci/controller/pcie-rockchip.c
@@ -24,6 +24,100 @@
 #include "../pci.h"
 #include "pcie-rockchip.h"
 
+static int rockchip_pcie_pm_reset_assert_one(struct rockchip_pcie *rockchip,
+					     unsigned int index, const char *name)
+{
+	int err;
+
+	err = reset_control_assert(rockchip->pm_rsts[index].rstc);
+	if (err)
+		dev_err(rockchip->dev, "assert %s reset err %d\n", name, err);
+
+	return err;
+}
+
+static int rockchip_pcie_pm_reset_deassert_one(struct rockchip_pcie *rockchip,
+					       unsigned int index, const char *name)
+{
+	int err;
+
+	err = reset_control_deassert(rockchip->pm_rsts[index].rstc);
+	if (err)
+		dev_err(rockchip->dev, "deassert %s reset err %d\n", name, err);
+
+	return err;
+}
+
+static int rockchip_pcie_core_reset_assert_one(struct rockchip_pcie *rockchip,
+					       unsigned int index, const char *name)
+{
+	int err;
+
+	err = reset_control_assert(rockchip->core_rsts[index].rstc);
+	if (err)
+		dev_err(rockchip->dev, "assert %s reset err %d\n", name, err);
+
+	return err;
+}
+
+static int rockchip_pcie_assert_pm_resets(struct rockchip_pcie *rockchip)
+{
+	int err;
+
+	/*
+	 * The RK3399 PCIe controller historically used this PM reset sequence:
+	 * assert aclk, pclk, pm; deassert pm, aclk, pclk. That sequence is not
+	 * expressible as a single reset_control_bulk_*() array because bulk
+	 * deassert runs in reverse order. Keep the bulk-acquired reset controls,
+	 * but drive the PM resets explicitly so the hardware sequence is preserved.
+	 */
+	err = rockchip_pcie_pm_reset_assert_one(rockchip, 2, "aclk");
+	if (err)
+		return err;
+	err = rockchip_pcie_pm_reset_assert_one(rockchip, 1, "pclk");
+	if (err)
+		return err;
+
+	return rockchip_pcie_pm_reset_assert_one(rockchip, 0, "pm");
+}
+
+static int rockchip_pcie_deassert_pm_resets(struct rockchip_pcie *rockchip)
+{
+	int err;
+
+	err = rockchip_pcie_pm_reset_deassert_one(rockchip, 0, "pm");
+	if (err)
+		return err;
+	err = rockchip_pcie_pm_reset_deassert_one(rockchip, 2, "aclk");
+	if (err)
+		return err;
+
+	return rockchip_pcie_pm_reset_deassert_one(rockchip, 1, "pclk");
+}
+
+static int rockchip_pcie_assert_core_resets(struct rockchip_pcie *rockchip)
+{
+	int err;
+
+	/*
+	 * Preserve the historical RK3399 core reset assert sequence:
+	 * core, mgmt, mgmt-sticky, pipe. Core reset deassertion still uses
+	 * reset_control_bulk_deassert(); its reverse order already matches the
+	 * historical deassert sequence: mgmt-sticky, core, mgmt, pipe.
+	 */
+	err = rockchip_pcie_core_reset_assert_one(rockchip, 2, "core");
+	if (err)
+		return err;
+	err = rockchip_pcie_core_reset_assert_one(rockchip, 1, "mgmt");
+	if (err)
+		return err;
+	err = rockchip_pcie_core_reset_assert_one(rockchip, 3, "mgmt-sticky");
+	if (err)
+		return err;
+
+	return rockchip_pcie_core_reset_assert_one(rockchip, 0, "pipe");
+}
+
 int rockchip_pcie_parse_dt(struct rockchip_pcie *rockchip)
 {
 	struct device *dev = rockchip->dev;
@@ -122,8 +216,7 @@
 	int err, i;
 	u32 regs;
 
-	err = reset_control_bulk_assert(ROCKCHIP_NUM_PM_RSTS,
-					rockchip->pm_rsts);
+	err = rockchip_pcie_assert_pm_resets(rockchip);
 	if (err)
 		return dev_err_probe(dev, err, "Couldn't assert PM resets\n");
 
@@ -135,8 +228,7 @@
 		}
 	}
 
-	err = reset_control_bulk_assert(ROCKCHIP_NUM_CORE_RSTS,
-					rockchip->core_rsts);
+	err = rockchip_pcie_assert_core_resets(rockchip);
 	if (err) {
 		dev_err_probe(dev, err, "Couldn't assert Core resets\n");
 		goto err_exit_phy;
@@ -144,8 +236,7 @@
 
 	udelay(10);
 
-	err = reset_control_bulk_deassert(ROCKCHIP_NUM_PM_RSTS,
-					  rockchip->pm_rsts);
+	err = rockchip_pcie_deassert_pm_resets(rockchip);
 	if (err) {
 		dev_err(dev, "Couldn't deassert PM resets %d\n", err);
 		goto err_exit_phy;

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@local>
Date: Thu, 18 Jun 2026 14:10:00 +0100
Subject: [PATCH] phy: rockchip-pcie: Restore RK3399 6.1 refclk lifecycle

The known-good Rock Pi 4 / RK3399 Armbian 6.1 PCIe PHY path got the
PCIe PHY reference clock during probe, but only prepared/enabled it from
the PHY init path.  The clock was disabled/unprepared again from the PHY
exit path.

Newer kernels use devm_clk_get_enabled() during probe, so the reference
clock is enabled earlier and kept enabled for the device lifetime.  That
is a reasonable cleanup, but it is a pre-link PHY sequencing delta from
the 6.1 baseline known to train this Rock Pi 4 / PCIe SATA setup.

Restore the 6.1 reference-clock lifecycle for this RK3399 compatibility
build:

  - get the refclk in probe without enabling it,
  - enable it on the first shared PHY init,
  - disable it on the matching final PHY exit,
  - unwind the clock if PHY reset assertion fails during init.

Signed-off-by: Codex <codex@local>
---
--- a/drivers/phy/rockchip/phy-rockchip-pcie.c
+++ b/drivers/phy/rockchip/phy-rockchip-pcie.c
@@ -214,13 +214,24 @@
 		return 0;
 	}
 
+	err = clk_prepare_enable(rk_phy->clk_pciephy_ref);
+	if (err) {
+		dev_err(&phy->dev, "Fail to enable pcie ref clock.\n");
+		goto err_refclk;
+	}
+
 	err = reset_control_assert(rk_phy->phy_rst);
 	if (err) {
 		dev_err(&phy->dev, "assert phy_rst err %d\n", err);
-		rk_phy->init_cnt--;
-		return err;
+		goto err_reset;
 	}
 
+	return 0;
+
+err_reset:
+	clk_disable_unprepare(rk_phy->clk_pciephy_ref);
+err_refclk:
+	rk_phy->init_cnt--;
 	return err;
 }
 
@@ -232,9 +243,9 @@
 	guard(mutex)(&rk_phy->pcie_mutex);
 
 	if (--rk_phy->init_cnt)
-		goto err_init_cnt;
+		return 0;
 
-err_init_cnt:
+	clk_disable_unprepare(rk_phy->clk_pciephy_ref);
 	return 0;
 }
 
@@ -294,7 +305,7 @@
 		return dev_err_probe(&pdev->dev, PTR_ERR(rk_phy->phy_rst),
 				     "missing phy property for reset controller\n");
 
-	rk_phy->clk_pciephy_ref = devm_clk_get_enabled(dev, "refclk");
+	rk_phy->clk_pciephy_ref = devm_clk_get(dev, "refclk");
 	if (IS_ERR(rk_phy->clk_pciephy_ref))
 		return dev_err_probe(&pdev->dev, PTR_ERR(rk_phy->clk_pciephy_ref),
 				     "failed to get phyclk\n");
